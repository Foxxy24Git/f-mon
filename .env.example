# F-mon — contoh environment variables.
# Salin ke .env lalu isi nilainya:  cp .env.example .env

# Database (cocok dengan docker-compose.yml service `db`)
DATABASE_URL="postgresql://fmon:password@localhost:5432/fmon"

# Auth (NextAuth). Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Ping worker
PING_INTERVAL_SEC=30
PING_TIMEOUT_MS=1000
PING_COUNT=3
PING_CONCURRENCY=100
FLAP_THRESHOLD=2

# Telegram alert (Fase 5)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# Retensi data ping mentah (hari)
RAW_RETENTION_DAYS=7
